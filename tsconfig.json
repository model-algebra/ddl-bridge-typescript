{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,

    "outDir": "dist",
    "sourceMap": true,

    "lib": ["ES2022"],

    "types": ["vitest/globals", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
